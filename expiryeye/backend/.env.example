PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/expiryeye
JWT_SECRET=change-this-to-a-long-random-string
# Days before expiry to flag “expiring soon” and send alerts (minimum 2).
ALERT_DAYS=7
EMAIL_USER=
EMAIL_PASS=

# Optional SMS (Twilio). User profile must include phone in E.164 (e.g. +9198...).
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# Optional: full public API origin for image URLs in production (e.g. https://api.example.com)
# PUBLIC_API_URL=

# After first deploy, run once from backend folder: npm run seed
# (adds demo medicines for the public “live evaluation” strip on the site)
